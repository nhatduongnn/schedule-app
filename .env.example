# Copy this to .env.local and fill in your keys
# NEVER commit .env.local to git

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- AI Keys (used only in /api/chat.js serverless function, never exposed to browser) ---

# Gemini — FREE default. Get key at aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here

# Claude — Optional paid fallback. Get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
